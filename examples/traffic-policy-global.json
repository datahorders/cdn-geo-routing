{
  "_description": "AWS Route 53 Traffic Policy with comprehensive global geo-routing",
  "_usage": [
    "1. Create traffic policy: aws route53 create-traffic-policy --name 'CDN Global' --document file://traffic-policy-global.json",
    "2. Create policy instance: aws route53 create-traffic-policy-instance --hosted-zone-id YOUR_ZONE_ID --name cdn.example.com --ttl 60 --traffic-policy-id POLICY_ID --traffic-policy-version 1"
  ],
  "_notes": [
    "This example provides comprehensive global coverage with continent and country-level routing",
    "North America: Routes to regional US pool endpoints (see traffic-policy-us-states.json for state-level)",
    "Europe: UK/Ireland to London, Western/Central Europe to Amsterdam, Eastern Europe to Warsaw",
    "Asia: All routes to Singapore",
    "Oceania: Routes to Sydney",
    "South America, Central America, Caribbean: Routes to Miami",
    "Africa and Middle East: Routes based on proximity to London or Amsterdam",
    "All endpoints have automatic failover built-in on the datahorders.org side",
    "For the simplest setup, customers can use cname.datahorders.org instead"
  ],
  "_coverage": {
    "North America": "us-west-1 (default), us-east-1 (Eastern Canada), us-west-2 (Western Canada), us-central-1 (Mexico)",
    "South America": "us-east-2",
    "Europe - London (eu-west-2)": "GB, IE, IS",
    "Europe - Amsterdam (eu-west-1)": "FR, ES, PT, NL, DE, AT, CH, BE, LU, DK, NO, SE, FI, IT, GR, MT, CY",
    "Europe - Warsaw (eu-central-2)": "PL, CZ, SK, HU, RO, BG, HR, SI, RS, BA, ME, MK, AL, EE, LV, LT, UA, BY, MD, RU, TR",
    "Africa - London (eu-west-2)": "NG, ZA, KE, ET, GH, TZ, UG, CD",
    "Africa - Amsterdam (eu-west-1)": "MA, DZ, TN, LY, EG, SD",
    "Middle East": "eu-west-1 (SA, AE, KW, QA, IL, IQ, IR)",
    "Asia": "ap-southeast-1",
    "Oceania": "ap-southeast-2"
  },

  "AWSPolicyFormatVersion": "2023-05-09",
  "RecordType": "CNAME",
  "StartRule": "geo-start",
  "Endpoints": {
    "ep-us-west-2": {"Type": "value", "Value": "cdn-us-west-2.datahorders.org"},
    "ep-us-west-1": {"Type": "value", "Value": "cdn-us-west-1.datahorders.org"},
    "ep-us-central-1": {"Type": "value", "Value": "cdn-us-central-1.datahorders.org"},
    "ep-us-east-1": {"Type": "value", "Value": "cdn-us-east-1.datahorders.org"},
    "ep-us-east-2": {"Type": "value", "Value": "cdn-us-east-2.datahorders.org"},
    "ep-eu-west-2": {"Type": "value", "Value": "cdn-eu-west-2.datahorders.org"},
    "ep-eu-west-1": {"Type": "value", "Value": "cdn-eu-west-1.datahorders.org"},
    "ep-eu-central-2": {"Type": "value", "Value": "cdn-eu-central-2.datahorders.org"},
    "ep-ap-southeast-1": {"Type": "value", "Value": "cdn-ap-southeast-1.datahorders.org"},
    "ep-ap-southeast-2": {"Type": "value", "Value": "cdn-ap-southeast-2.datahorders.org"}
  },
  "Rules": {
    "geo-start": {
      "RuleType": "geo",
      "Locations": [
        {"IsDefault": true, "EndpointReference": "ep-us-west-1"},
        {"Continent": "NA", "RuleReference": "geo-north-america"},
        {"Continent": "SA", "EndpointReference": "ep-us-east-2"},
        {"Continent": "EU", "RuleReference": "geo-europe"},
        {"Continent": "AF", "RuleReference": "geo-africa"},
        {"Continent": "AS", "RuleReference": "geo-asia"},
        {"Continent": "OC", "RuleReference": "geo-oceania"}
      ]
    },
    "geo-north-america": {
      "RuleType": "geo",
      "Locations": [
        {"IsDefault": true, "EndpointReference": "ep-us-west-1"},
        {"Country": "US", "EndpointReference": "ep-us-west-1"},
        {"Country": "CA", "RuleReference": "geo-canada"},
        {"Country": "MX", "EndpointReference": "ep-us-central-1"},
        {"Country": "GT", "EndpointReference": "ep-us-east-2"},
        {"Country": "BZ", "EndpointReference": "ep-us-east-2"},
        {"Country": "HN", "EndpointReference": "ep-us-east-2"},
        {"Country": "SV", "EndpointReference": "ep-us-east-2"},
        {"Country": "NI", "EndpointReference": "ep-us-east-2"},
        {"Country": "CR", "EndpointReference": "ep-us-east-2"},
        {"Country": "PA", "EndpointReference": "ep-us-east-2"},
        {"Country": "CU", "EndpointReference": "ep-us-east-2"},
        {"Country": "JM", "EndpointReference": "ep-us-east-2"},
        {"Country": "HT", "EndpointReference": "ep-us-east-2"},
        {"Country": "DO", "EndpointReference": "ep-us-east-2"},
        {"Country": "BS", "EndpointReference": "ep-us-east-2"},
        {"Country": "BB", "EndpointReference": "ep-us-east-2"},
        {"Country": "TT", "EndpointReference": "ep-us-east-2"}
      ]
    },
    "geo-canada": {
      "RuleType": "geoproximity",
      "GeoproximityLocations": [
        {
          "EndpointReference": "ep-us-east-1",
          "Latitude": "43.6532",
          "Longitude": "-79.3832",
          "Bias": 0
        },
        {
          "EndpointReference": "ep-us-west-2",
          "Latitude": "49.2827",
          "Longitude": "-123.1207",
          "Bias": 0
        }
      ]
    },
    "geo-europe": {
      "RuleType": "geo",
      "Locations": [
        {"IsDefault": true, "EndpointReference": "ep-eu-west-1"},

        {"Country": "GB", "EndpointReference": "ep-eu-west-2"},
        {"Country": "IE", "EndpointReference": "ep-eu-west-2"},
        {"Country": "IS", "EndpointReference": "ep-eu-west-2"},

        {"Country": "FR", "EndpointReference": "ep-eu-west-1"},
        {"Country": "ES", "EndpointReference": "ep-eu-west-1"},
        {"Country": "PT", "EndpointReference": "ep-eu-west-1"},
        {"Country": "NL", "EndpointReference": "ep-eu-west-1"},
        {"Country": "DE", "EndpointReference": "ep-eu-west-1"},
        {"Country": "AT", "EndpointReference": "ep-eu-west-1"},
        {"Country": "CH", "EndpointReference": "ep-eu-west-1"},
        {"Country": "BE", "EndpointReference": "ep-eu-west-1"},
        {"Country": "LU", "EndpointReference": "ep-eu-west-1"},
        {"Country": "DK", "EndpointReference": "ep-eu-west-1"},
        {"Country": "NO", "EndpointReference": "ep-eu-west-1"},
        {"Country": "SE", "EndpointReference": "ep-eu-west-1"},
        {"Country": "FI", "EndpointReference": "ep-eu-west-1"},
        {"Country": "IT", "EndpointReference": "ep-eu-west-1"},
        {"Country": "GR", "EndpointReference": "ep-eu-west-1"},
        {"Country": "MT", "EndpointReference": "ep-eu-west-1"},
        {"Country": "CY", "EndpointReference": "ep-eu-west-1"},

        {"Country": "PL", "EndpointReference": "ep-eu-central-2"},
        {"Country": "CZ", "EndpointReference": "ep-eu-central-2"},
        {"Country": "SK", "EndpointReference": "ep-eu-central-2"},
        {"Country": "HU", "EndpointReference": "ep-eu-central-2"},
        {"Country": "RO", "EndpointReference": "ep-eu-central-2"},
        {"Country": "BG", "EndpointReference": "ep-eu-central-2"},
        {"Country": "HR", "EndpointReference": "ep-eu-central-2"},
        {"Country": "SI", "EndpointReference": "ep-eu-central-2"},
        {"Country": "RS", "EndpointReference": "ep-eu-central-2"},
        {"Country": "BA", "EndpointReference": "ep-eu-central-2"},
        {"Country": "ME", "EndpointReference": "ep-eu-central-2"},
        {"Country": "MK", "EndpointReference": "ep-eu-central-2"},
        {"Country": "AL", "EndpointReference": "ep-eu-central-2"},
        {"Country": "EE", "EndpointReference": "ep-eu-central-2"},
        {"Country": "LV", "EndpointReference": "ep-eu-central-2"},
        {"Country": "LT", "EndpointReference": "ep-eu-central-2"},
        {"Country": "UA", "EndpointReference": "ep-eu-central-2"},
        {"Country": "BY", "EndpointReference": "ep-eu-central-2"},
        {"Country": "MD", "EndpointReference": "ep-eu-central-2"},
        {"Country": "RU", "EndpointReference": "ep-eu-central-2"},
        {"Country": "TR", "EndpointReference": "ep-eu-central-2"}
      ]
    },
    "geo-africa": {
      "RuleType": "geo",
      "Locations": [
        {"IsDefault": true, "EndpointReference": "ep-eu-west-2"},

        {"Country": "MA", "EndpointReference": "ep-eu-west-1"},
        {"Country": "DZ", "EndpointReference": "ep-eu-west-1"},
        {"Country": "TN", "EndpointReference": "ep-eu-west-1"},
        {"Country": "LY", "EndpointReference": "ep-eu-west-1"},
        {"Country": "EG", "EndpointReference": "ep-eu-west-1"},
        {"Country": "SD", "EndpointReference": "ep-eu-west-1"},

        {"Country": "NG", "EndpointReference": "ep-eu-west-2"},
        {"Country": "ZA", "EndpointReference": "ep-eu-west-2"},
        {"Country": "KE", "EndpointReference": "ep-eu-west-2"},
        {"Country": "ET", "EndpointReference": "ep-eu-west-2"},
        {"Country": "GH", "EndpointReference": "ep-eu-west-2"},
        {"Country": "TZ", "EndpointReference": "ep-eu-west-2"},
        {"Country": "UG", "EndpointReference": "ep-eu-west-2"},
        {"Country": "CD", "EndpointReference": "ep-eu-west-2"}
      ]
    },
    "geo-asia": {
      "RuleType": "geo",
      "Locations": [
        {"IsDefault": true, "EndpointReference": "ep-ap-southeast-1"},

        {"Country": "SA", "EndpointReference": "ep-eu-west-1"},
        {"Country": "AE", "EndpointReference": "ep-eu-west-1"},
        {"Country": "KW", "EndpointReference": "ep-eu-west-1"},
        {"Country": "QA", "EndpointReference": "ep-eu-west-1"},
        {"Country": "IL", "EndpointReference": "ep-eu-west-1"},
        {"Country": "IQ", "EndpointReference": "ep-eu-west-1"},
        {"Country": "IR", "EndpointReference": "ep-eu-west-1"},
        {"Country": "KZ", "EndpointReference": "ep-eu-west-1"},
        {"Country": "UZ", "EndpointReference": "ep-eu-west-1"},

        {"Country": "CN", "EndpointReference": "ep-ap-southeast-1"},
        {"Country": "HK", "EndpointReference": "ep-ap-southeast-1"},
        {"Country": "TW", "EndpointReference": "ep-ap-southeast-1"},
        {"Country": "JP", "EndpointReference": "ep-ap-southeast-1"},
        {"Country": "KR", "EndpointReference": "ep-ap-southeast-1"},
        {"Country": "SG", "EndpointReference": "ep-ap-southeast-1"},
        {"Country": "MY", "EndpointReference": "ep-ap-southeast-1"},
        {"Country": "TH", "EndpointReference": "ep-ap-southeast-1"},
        {"Country": "VN", "EndpointReference": "ep-ap-southeast-1"},
        {"Country": "PH", "EndpointReference": "ep-ap-southeast-1"},
        {"Country": "ID", "EndpointReference": "ep-ap-southeast-1"},
        {"Country": "IN", "EndpointReference": "ep-ap-southeast-1"},
        {"Country": "BD", "EndpointReference": "ep-ap-southeast-1"},
        {"Country": "PK", "EndpointReference": "ep-ap-southeast-1"}
      ]
    },
    "geo-oceania": {
      "RuleType": "geo",
      "Locations": [
        {"IsDefault": true, "EndpointReference": "ep-ap-southeast-2"},
        {"Country": "AU", "EndpointReference": "ep-ap-southeast-2"},
        {"Country": "NZ", "EndpointReference": "ep-ap-southeast-2"}
      ]
    }
  }
}
