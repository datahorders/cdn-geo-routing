{
  "_description": "AWS Route 53 Traffic Policy with US state-level geo-routing",
  "_usage": [
    "1. Create traffic policy: aws route53 create-traffic-policy --name 'CDN US States' --document file://traffic-policy-us-states.json",
    "2. Create policy instance: aws route53 create-traffic-policy-instance --hosted-zone-id YOUR_ZONE_ID --name cdn.example.com --ttl 60 --traffic-policy-id POLICY_ID --traffic-policy-version 1"
  ],
  "_notes": [
    "This example routes US traffic to 5 regional CDN pool endpoints based on state",
    "Canada routes to us-east-1 (Eastern) or us-west-2 (Western) based on geoproximity",
    "Mexico routes to us-central-1 (Dallas)",
    "Default fallback is us-west-1 (Los Angeles)",
    "All endpoints have automatic failover built-in on the datahorders.org side"
  ],
  "_endpoints": {
    "Seattle (us-west-2)": "WA, OR, ID, MT, AK",
    "Los Angeles (us-west-1)": "CA, NV, AZ, UT, HI, WY + default",
    "Dallas (us-central-1)": "TX, OK, NM, AR, LA, KS, CO, GA, AL, MS, TN, KY + Mexico",
    "Ashburn (us-east-1)": "VA, MD, DC, DE, WV, NC, SC, NY, NJ, PA, CT, MA, RI, NH, VT, ME, OH, MI, IN, IL, WI, MN, IA, MO, NE, SD, ND + Eastern Canada",
    "Miami (us-east-2)": "FL"
  },

  "AWSPolicyFormatVersion": "2023-05-09",
  "RecordType": "CNAME",
  "StartRule": "geo-north-america",
  "Endpoints": {
    "ep-us-west-2": {"Type": "value", "Value": "cdn-us-west-2.datahorders.org"},
    "ep-us-west-1": {"Type": "value", "Value": "cdn-us-west-1.datahorders.org"},
    "ep-us-central-1": {"Type": "value", "Value": "cdn-us-central-1.datahorders.org"},
    "ep-us-east-1": {"Type": "value", "Value": "cdn-us-east-1.datahorders.org"},
    "ep-us-east-2": {"Type": "value", "Value": "cdn-us-east-2.datahorders.org"}
  },
  "Rules": {
    "geo-north-america": {
      "RuleType": "geo",
      "Locations": [
        {"IsDefault": true, "EndpointReference": "ep-us-west-1"},
        {"Country": "US", "RuleReference": "geo-us-states"},
        {"Country": "CA", "RuleReference": "geo-canada"},
        {"Country": "MX", "EndpointReference": "ep-us-central-1"}
      ]
    },
    "geo-us-states": {
      "RuleType": "geo",
      "Locations": [
        {"IsDefault": true, "EndpointReference": "ep-us-west-1"},

        {"Country": "US", "Subdivision": "WA", "EndpointReference": "ep-us-west-2"},
        {"Country": "US", "Subdivision": "OR", "EndpointReference": "ep-us-west-2"},
        {"Country": "US", "Subdivision": "ID", "EndpointReference": "ep-us-west-2"},
        {"Country": "US", "Subdivision": "MT", "EndpointReference": "ep-us-west-2"},
        {"Country": "US", "Subdivision": "AK", "EndpointReference": "ep-us-west-2"},

        {"Country": "US", "Subdivision": "CA", "EndpointReference": "ep-us-west-1"},
        {"Country": "US", "Subdivision": "NV", "EndpointReference": "ep-us-west-1"},
        {"Country": "US", "Subdivision": "AZ", "EndpointReference": "ep-us-west-1"},
        {"Country": "US", "Subdivision": "UT", "EndpointReference": "ep-us-west-1"},
        {"Country": "US", "Subdivision": "HI", "EndpointReference": "ep-us-west-1"},
        {"Country": "US", "Subdivision": "WY", "EndpointReference": "ep-us-west-1"},

        {"Country": "US", "Subdivision": "TX", "EndpointReference": "ep-us-central-1"},
        {"Country": "US", "Subdivision": "OK", "EndpointReference": "ep-us-central-1"},
        {"Country": "US", "Subdivision": "NM", "EndpointReference": "ep-us-central-1"},
        {"Country": "US", "Subdivision": "AR", "EndpointReference": "ep-us-central-1"},
        {"Country": "US", "Subdivision": "LA", "EndpointReference": "ep-us-central-1"},
        {"Country": "US", "Subdivision": "KS", "EndpointReference": "ep-us-central-1"},
        {"Country": "US", "Subdivision": "CO", "EndpointReference": "ep-us-central-1"},
        {"Country": "US", "Subdivision": "GA", "EndpointReference": "ep-us-central-1"},
        {"Country": "US", "Subdivision": "AL", "EndpointReference": "ep-us-central-1"},
        {"Country": "US", "Subdivision": "MS", "EndpointReference": "ep-us-central-1"},
        {"Country": "US", "Subdivision": "TN", "EndpointReference": "ep-us-central-1"},
        {"Country": "US", "Subdivision": "KY", "EndpointReference": "ep-us-central-1"},

        {"Country": "US", "Subdivision": "VA", "EndpointReference": "ep-us-east-1"},
        {"Country": "US", "Subdivision": "MD", "EndpointReference": "ep-us-east-1"},
        {"Country": "US", "Subdivision": "DC", "EndpointReference": "ep-us-east-1"},
        {"Country": "US", "Subdivision": "DE", "EndpointReference": "ep-us-east-1"},
        {"Country": "US", "Subdivision": "WV", "EndpointReference": "ep-us-east-1"},
        {"Country": "US", "Subdivision": "NC", "EndpointReference": "ep-us-east-1"},
        {"Country": "US", "Subdivision": "SC", "EndpointReference": "ep-us-east-1"},
        {"Country": "US", "Subdivision": "NY", "EndpointReference": "ep-us-east-1"},
        {"Country": "US", "Subdivision": "NJ", "EndpointReference": "ep-us-east-1"},
        {"Country": "US", "Subdivision": "PA", "EndpointReference": "ep-us-east-1"},
        {"Country": "US", "Subdivision": "CT", "EndpointReference": "ep-us-east-1"},
        {"Country": "US", "Subdivision": "MA", "EndpointReference": "ep-us-east-1"},
        {"Country": "US", "Subdivision": "RI", "EndpointReference": "ep-us-east-1"},
        {"Country": "US", "Subdivision": "NH", "EndpointReference": "ep-us-east-1"},
        {"Country": "US", "Subdivision": "VT", "EndpointReference": "ep-us-east-1"},
        {"Country": "US", "Subdivision": "ME", "EndpointReference": "ep-us-east-1"},
        {"Country": "US", "Subdivision": "OH", "EndpointReference": "ep-us-east-1"},
        {"Country": "US", "Subdivision": "MI", "EndpointReference": "ep-us-east-1"},
        {"Country": "US", "Subdivision": "IN", "EndpointReference": "ep-us-east-1"},
        {"Country": "US", "Subdivision": "IL", "EndpointReference": "ep-us-east-1"},
        {"Country": "US", "Subdivision": "WI", "EndpointReference": "ep-us-east-1"},
        {"Country": "US", "Subdivision": "MN", "EndpointReference": "ep-us-east-1"},
        {"Country": "US", "Subdivision": "IA", "EndpointReference": "ep-us-east-1"},
        {"Country": "US", "Subdivision": "MO", "EndpointReference": "ep-us-east-1"},
        {"Country": "US", "Subdivision": "NE", "EndpointReference": "ep-us-east-1"},
        {"Country": "US", "Subdivision": "SD", "EndpointReference": "ep-us-east-1"},
        {"Country": "US", "Subdivision": "ND", "EndpointReference": "ep-us-east-1"},

        {"Country": "US", "Subdivision": "FL", "EndpointReference": "ep-us-east-2"}
      ]
    },
    "geo-canada": {
      "RuleType": "geoproximity",
      "GeoproximityLocations": [
        {
          "EndpointReference": "ep-us-east-1",
          "Latitude": "43.6532",
          "Longitude": "-79.3832",
          "Bias": 0
        },
        {
          "EndpointReference": "ep-us-west-2",
          "Latitude": "49.2827",
          "Longitude": "-123.1207",
          "Bias": 0
        }
      ]
    }
  }
}
